{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(./.claude/**)",
      "Write(./.claude/memory/**)",
      "Write(./.claude/skills/**)",
      "Edit(./.claude/memory/**)",
      "Edit(./.claude/SOUL.md)",
      "Bash(python3 .claude/skills/memory-init/scripts/extract_candidates.py:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/session_start.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/capture_signal.py"
          }
        ]
      }
    ]
  }
}
